# ─── Madix Bot — Configuration Template ──────────────────────────────────────
# Copy this file to .env and fill in your values before running the bot.
#
#   cp .env.example .env
#   nano .env
#
# IMPORTANT: Never commit .env to version control. It contains secret keys.
# ──────────────────────────────────────────────────────────────────────────────

# Your bot's API token from @BotFather on Telegram.
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs that will have full admin access.
# To find your ID, message @userinfobot on Telegram.
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=your_telegram_user_id_here

# Telegram handle for your support account or channel.
# Shown to users when they tap the Support button.
SUPPORT_HANDLE=@YourSupportHandle

# The name of your shop, shown to users in greeting and welcome messages.
# This is your brand — choose something recognizable.
SHOP_NAME=My Shop
